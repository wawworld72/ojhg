# Database
POSTGRES_PASSWORD=judgepass
DATABASE_URL=postgresql+asyncpg://judge:judgepass@postgres:5432/onlinejudge

# Redis
REDIS_URL=redis://redis:6379/0

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Security
# SECRET_KEY: 32+ random bytes for session signing
SECRET_KEY=change-me-to-a-random-32-char-string
# ENCRYPTION_KEY: exactly 32 bytes for AES-256 token encryption
ENCRYPTION_KEY=change-me-to-exactly-32-bytes!!!

# GitHub OAuth (optional — enables Publish feature)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Frontend
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Cloudflare Tunnel (production)
# CLOUDFLARE_TUNNEL_TOKEN=
